---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { cv } from "../../data/cv-data.mjs";
import { locales, ui } from "../../data/site.mjs";

export const getStaticPaths = () => locales.map((locale) => ({ params: { locale } }));

const locale = (Astro.params.locale || "en") as "en" | "de" | "da";
const data = cv[locale];
const copy = ui[locale];
const labels = data.labels;
const pageOneEngagements = data.engagements.slice(0, 3);
const pageTwoEngagements = data.engagements.slice(3);
---
<BaseLayout title={`CV | ${data.name}`} description={data.profile.join(" ")} locale={locale} path={`/${locale}/cv/`}>
  <section class="cv-toolbar" aria-label="CV downloads">
    <div>
      <p class="eyebrow">{data.descriptor}</p>
      <h1>{labels.cv}</h1>
    </div>
    <div class="actions">
      <a class="button" href={`/downloads/cv/michael-moeller-cv-${locale}.pdf`}>{copy.downloadPdf}</a>
      <a class="button secondary" href={`/downloads/cv/michael-moeller-cv-${locale}.docx`}>{copy.downloadDocx}</a>
    </div>
  </section>

  <section class="cv-sheets" aria-label={`${data.name} CV`}>
    <article class="cv-page">
      <header class="cv-header">
        <img src="/images/michael-moeller-headshot.png" alt="" loading="eager" />
        <div>
          <p class="cv-kicker">{data.headline}</p>
          <h2>{data.name}</h2>
          <p class="cv-descriptor">{data.descriptor}</p>
          <a href={data.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
        </div>
      </header>

      <div class="cv-layout">
        <aside class="cv-sidebar">
          <section>
            <h3>{labels.expertise}</h3>
            {data.expertise.slice(0, 4).map((group: any) => (
              <div class="cv-side-group">
                <h4>{group.title}</h4>
                <ul>{group.items.map((item: string) => <li>{item}</li>)}</ul>
              </div>
            ))}
          </section>
          <section>
            <h3>{labels.languages}</h3>
            <p>{data.languages}</p>
          </section>
        </aside>

        <main class="cv-main">
          <section class="cv-section profile">
            <h3>{labels.profile}</h3>
            {data.profile.map((line: string) => <p>{line}</p>)}
          </section>
          <section class="cv-section">
            <h3>{labels.selectedEngagements}</h3>
            <div class="cv-engagements">
              {pageOneEngagements.map((item: any) => (
                <article class="cv-engagement">
                  <p class="cv-period">{item.period}</p>
                  <h4>{item.title}</h4>
                  <p class="cv-client">{item.client}</p>
                  <p>{item.summary}</p>
                  <ul>{item.focus.map((focus: string) => <li>{focus}</li>)}</ul>
                </article>
              ))}
            </div>
          </section>
        </main>
      </div>
      <footer class="cv-page-number">1 / 2</footer>
    </article>

    <article class="cv-page">
      <div class="cv-layout continuation">
        <aside class="cv-sidebar">
          <section>
            <h3>{labels.certifications}</h3>
            <ul>{data.certifications.map((item: string) => <li>{item}</li>)}</ul>
          </section>
          <section>
            <h3>{labels.education}</h3>
            {data.education.map((item: any) => <p><strong>{item.title}</strong><br />{item.place}<br />{item.year}</p>)}
          </section>
          <section>
            <h3>{labels.secondaryCapabilities}</h3>
            <p>{data.expertise[4].items[0]}</p>
          </section>
        </aside>

        <main class="cv-main">
          <section class="cv-section continued">
            <h3>{labels.selectedEngagements}</h3>
            <div class="cv-engagements">
              {pageTwoEngagements.map((item: any) => (
                <article class="cv-engagement">
                  <p class="cv-period">{item.period}</p>
                  <h4>{item.title}</h4>
                  <p class="cv-client">{item.client}</p>
                  <p>{item.summary}</p>
                  <ul>{item.focus.map((focus: string) => <li>{focus}</li>)}</ul>
                  {item.note && <p class="cv-note">{item.note}</p>}
                </article>
              ))}
            </div>
          </section>

          <section class="cv-section earlier">
            <h3>{labels.earlierExperience}</h3>
            <div class="cv-timeline">
              {data.earlierCareer.map((item: any) => (
                <div>
                  <span>{item.period}</span>
                  <p><strong>{item.client}</strong><br />{item.role}</p>
                </div>
              ))}
            </div>
          </section>
        </main>
      </div>
      <footer class="cv-page-number">2 / 2</footer>
    </article>
  </section>
</BaseLayout>
