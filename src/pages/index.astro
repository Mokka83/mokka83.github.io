---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import EngagementList from "../components/EngagementList.astro";
import ExpertiseGrid from "../components/ExpertiseGrid.astro";
import { cv } from "../data/cv-data.mjs";
import { ui } from "../data/site.mjs";

const data = cv.en;
const copy = ui.en;
---
<BaseLayout title={`${data.name} | ${data.headline}`} description={data.profile[0]} locale="en" path="/">
  <Hero cv={data} ui={copy} />
  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">{data.headline}</p>
      <h2>{data.engagementTitle}</h2>
      <p>{data.engagementNote}</p>
    </div>
    <EngagementList cv={data} limit={4} />
  </section>
  <section class="section muted">
    <div class="section-heading">
      <p class="eyebrow">Capabilities</p>
      <h2>Expertise grouped by delivery outcome</h2>
    </div>
    <ExpertiseGrid items={data.expertise} />
  </section>
</BaseLayout>
